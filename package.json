{
  "name": "ast-grep-mcp",
  "version": "0.0.0",
  "description": "MCP stdio server exposing ast-grep structural search and safe rewrites to agents",
  "keywords": [
    "ast-grep",
    "codemod",
    "mcp",
    "model-context-protocol",
    "structural-search",
    "typescript"
  ],
  "homepage": "https://github.com/spiritledsoftware/ast-grep-mcp#readme",
  "bugs": {
    "url": "https://github.com/spiritledsoftware/ast-grep-mcp/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spiritledsoftware/ast-grep-mcp.git"
  },
  "bin": {
    "ast-grep-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "README.md"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "pnpm run clean && tsc -p tsconfig.build.json && rolldown -c",
    "changeset": "changeset",
    "clean": "rm -rf dist",
    "dev": "tsx src/index.ts",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "pack:dry-run": "pnpm run build && npm pack --dry-run",
    "prepublishOnly": "pnpm run verify",
    "release": "pnpm run verify && changeset publish",
    "test": "vitest run",
    "typecheck": "tsc",
    "verify": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build",
    "version-packages": "changeset version"
  },
  "dependencies": {
    "@ast-grep/cli": "^0.42.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^25.9.1",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "rolldown": "^1.0.2",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.3.0"
}
